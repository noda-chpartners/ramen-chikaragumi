---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

import Logo from '../../assets/images/logo2.png';

const navLinks = [
  { href: '#about', label: '当店について' },
  { href: '#menu', label: 'お品書き' },
  { href: '#info', label: '店舗情報' },
  { href: '#contact', label: 'お問い合わせ' },
];

const tel = '09071624273';
const telDisplay = '090-7162-4273';
---
<header class="header">
  <div class="header-inner">
    <h1 class="logo">
      <a href="/" class="logo-link">
        <Image src={Logo} alt={siteConfig.title} />
        <span class="logo-tagline">初代組系ラーメン</span>
      </a>
    </h1>

    <nav class="nav" id="global-nav" aria-label="メインナビゲーション">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class="nav-item">
            <a href={link.href} class="nav-link" data-nav-link>{link.label}</a>
          </li>
        ))}
      </ul>

      <div class="nav-actions">
        <a href={`tel:${tel}`} class="tel-button">
          <span class="tel-text">{telDisplay}</span>
        </a>
        <ul class="sns-list">
          <li>
            <a href={siteConfig.sns.x} class="sns-link" target="_blank" rel="noopener noreferrer" aria-label="X">
              <Icon name="simple-icons:x" />
            </a>
          </li>
          <li>
            <a href={siteConfig.sns.instagram} class="sns-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <Icon name="simple-icons:instagram" />
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <button
      type="button"
      class="hamburger"
      id="hamburger"
      aria-label="メニューを開く"
      aria-controls="global-nav"
      aria-expanded="false"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>
</header>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 110;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 20px 40px;

    @include tb {
      padding: 16px 20px;
    }
  }

  .logo {
    position: relative;
    z-index: 120;
    max-width: 150px;
    height: auto;
  }

  .logo-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .logo-tagline {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }

  /* ===== PC: 横並びナビ ===== */
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(24px, 4vw, 56px);
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2.5vw, 36px);
  }

  .nav-link {
    font-size: 1rem;
    letter-spacing: 0.05em;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.6;
    }
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .tel-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 999px;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;

    &:hover {
      background-color: #fff;
      color: #000;
    }
  }

  .tel-icon {
    font-size: 1rem;
  }

  .sns-list {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .sns-link {
    display: flex;
    align-items: center;
    font-size: 1.4rem;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.6;
    }
  }

  /* ===== ハンバーガー（PCでは非表示） ===== */
  .hamburger {
    display: none;
    position: relative;
    z-index: 120;
    width: 32px;
    height: 24px;
    background: transparent;
  }

  .hamburger-bar {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #fff;
    transition: transform 0.3s, opacity 0.3s;

    &:nth-child(1) { top: 0; }
    &:nth-child(2) { top: 50%; transform: translateY(-50%); }
    &:nth-child(3) { bottom: 0; }
  }

  /* ===== スマホ/タブレット: オーバーレイドロワー ===== */
  @include tb {
    .hamburger {
      display: block;
    }

    .nav {
      position: fixed;
      inset: 0;
      z-index: 100;
      flex-direction: column;
      justify-content: center;
      gap: 48px;
      background-color: rgba(0, 0, 0, 0.95);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.3s, visibility 0.3s;
    }

    .nav-list {
      flex-direction: column;
      gap: 32px;
      text-align: center;
    }

    .nav-link {
      font-size: 1.25rem;
    }

    .nav-actions {
      flex-direction: column;
      gap: 28px;
    }

    .tel-button {
      font-size: 1.05rem;
      padding: 12px 28px;
    }

    .sns-link {
      font-size: 1.8rem;
    }

    /* 開いた状態（bodyにクラスを付与して制御） */
    :global(body.is-nav-open) .nav {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    /* ハンバーガー → ×印 */
    :global(body.is-nav-open) .hamburger-bar {
      &:nth-child(1) {
        top: 50%;
        transform: translateY(-50%) rotate(45deg);
      }
      &:nth-child(2) {
        opacity: 0;
      }
      &:nth-child(3) {
        bottom: 50%;
        transform: translateY(50%) rotate(-45deg);
      }
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const body = document.body;

  const closeNav = () => {
    body.classList.remove('is-nav-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.setAttribute('aria-label', 'メニューを開く');
  };

  hamburger?.addEventListener('click', () => {
    const isOpen = body.classList.toggle('is-nav-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
  });

  // ナビ内リンクをタップしたら閉じる（アンカー遷移後にメニューを残さない）
  document.querySelectorAll('[data-nav-link]').forEach((link) => {
    link.addEventListener('click', closeNav);
  });

  // Escキーで閉じる
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });
</script>