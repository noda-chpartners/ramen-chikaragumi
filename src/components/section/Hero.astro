---
import { getImage } from 'astro:assets';

import pcHero from '../../assets/images/pc-hero.png';
import tabHero from '../../assets/images/tab-hero.png';
import spHero from '../../assets/images/sp-hero.png';

const pc = await getImage({ src: pcHero, format: 'webp' });
const tab = await getImage({ src: tabHero, format: 'webp' });
const sp = await getImage({ src: spHero, format: 'webp' });
---
<section class="hero">
    <picture class="hero-picture">
      <source media="(max-width: 520px)" srcset={sp.src} />
      <source media="(max-width: 890px)" srcset={tab.src} />
      <img
        src={pc.src}
        alt="初代組系ラーメン麵魂力組"
        data-hero-image
      />
    </picture>

    <div class="hero-copy" aria-label="魂を込めた一杯。受け継がれる屋台の味。飯田橋に、再び。">
      <p class="hero-copy-line" aria-hidden="true">
        {'屋台からスタートし、'.split('').map((char) => (
          <span class="hero-copy-char">{char}</span>
        ))}
      </p>
      <p class="hero-copy-line" aria-hidden="true">
        {'全国のラーメンテーマパークで'.split('').map((char) => (
          <span class="hero-copy-char">{char}</span>
        ))}
      </p>
      <p class="hero-copy-line" aria-hidden="true">
        {'名を馳せた伝説の店主が腕を振るう名作。'.split('').map((char) => (
          <span class="hero-copy-char">{char}</span>
        ))}
      </p>
      <p class="hero-copy-line" aria-hidden="true">
        {'今、ここに復活'.split('').map((char) => (
          <span class="hero-copy-char">{char}</span>
        ))}
      </p>
      <p class="hero-copy-line" aria-hidden="true">
        {'魂の一杯'.split('').map((char) => (
          <span class="hero-copy-char">{char}</span>
        ))}
      </p>
    </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .hero {
    position: relative; 
    width: 100%;
    height: 100dvh;
    overflow: hidden;

    &::after {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.55) 0%,
        rgba(0, 0, 0, 0.22) 34%,
        rgba(0, 0, 0, 0) 68%
      );
      content: "";
      pointer-events: none;
    }
  }


  

  .hero-picture {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-picture img {
    object-fit: cover;
    object-position: center;
  }

  .hero-copy {
    position: absolute;
    top: 50%;
    left: clamp(72px, 22vw, 30%);
    z-index: 2;
    display: flex;
    flex-direction: row-reverse;
    align-items: flex-start;
    gap: clamp(16px, 2.5vw, 32px);
    transform: translateY(-50%);
  }

  .hero-copy-line {
    margin: 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    color: #fff;
    font-size: clamp(1rem, 3vw, 1rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.75);
    white-space: nowrap;
  }

  .hero-copy-char {
    display: inline-block;
    overflow: hidden;
    transform-origin: top center;
    will-change: transform, opacity;
  }

  @include sp {
    .hero-copy {
      left: clamp(32px, 14vw, 22%);
      gap: 12px;
    }

    .hero-copy-line {
      letter-spacing: 0.14em;
    }
  }
</style>