---
import { Image } from 'astro:assets';

import ramen01 from '../../assets/images/ramenAll01.png';
import ramen02 from '../../assets/images/tuke.png';
import ramen03 from '../../assets/images/sio2.png';
import ramen04 from '../../assets/images/miso01.png';
import item05 from '../../assets/images/rice.png';
import deco from '../../assets/images/deco.png';

---
<section class="section menu" id="menu">
  <div class="inner">
    <div class="section-title">
      <h2 class="title">お品書き</h2>
    </div>
    <div class="content">
      <ul class="menu-list">
        <li class="menu-item">
          <div class="menu-text">
            <div class="menu-title-wrap">
              <Image class="menu-deco" src={ deco } alt="" aria-hidden="true" />
              <h3 class="menu-title">正油ラーメン<span class="title-small">全部のせ</span></h3>
            </div>
            <p class="text">正油ラーメンに深みのある味わいと<br class="break" />味が染みたやわらかいチャーシュー満足感の高い一杯に。</p>
          </div>
          <figure class="menu-image">
            <Image src={ ramen01 } alt="正油ラーメン全部のせ" />
          </figure>
        </li>
        <li class="menu-item">
          <div class="menu-text">
            <div class="menu-title-wrap">
              <Image class="menu-deco" src={ deco } alt="" aria-hidden="true" />
              <h3 class="menu-title">塩ラーメン</h3>
            </div> 
            <p class="text">こだわりの塩を使いあっさり（しじみ・まぐろ）<br class="break" />だしがふんだんに入った感動の味</p>
          </div>
          <figure class="menu-image">
            <Image src={ ramen03 } alt="塩ラーメン" />
          </figure>
        </li>
        <li class="menu-item">
          <div class="menu-text">
            <div class="menu-title-wrap">
              <Image class="menu-deco" src={ deco } alt="" aria-hidden="true" />
              <h3 class="menu-title">辛味噌ラーメン</h3>
            </div>
            <p class="text">山形県白鷹町の幻の味噌蔵より届く貴重な味噌を使い、<br class="break" />辛みその薬味はうまみの詰まった唐辛子と数種の醤との組み合わせで絶妙な味。</p>
          </div>
          <figure class="menu-image">
            <Image class="image" src={ ramen04 } alt="辛味噌ラーメン" />
          </figure>
        </li>
        <li class="menu-item">
          <div class="menu-text">
            <div class="menu-title-wrap">
              <Image class="menu-deco" src={ deco } alt="" aria-hidden="true" />
              <h3 class="menu-title">つけ麺</h3>
            </div>
            <p class="text">力強い極太麺に、正油の旨味を凝縮した濃厚つけダレ。麺を引き上げるたびに、力組らしい深いコクが口いっぱいに広がります。</p>
          </div>
          <figure class="menu-image">
            <Image class="image" src={ ramen02 } alt="辛味噌ラーメン" />
          </figure>
        </li>
      </ul>
      <div class="submenu">
        <div class="submenu-head">
          <h3 class="submenu-heading">こんな一品もございます</h3>
        </div>
        <ul class="submenu-list">
          <li class="submenu-item">
            <figure class="submenu-image">
              <Image src={ item05 } alt="チャーハン" />
            </figure>
            <h4 class="submenu-name">チャーハン</h4>
          </li>
        </ul>
        <div class="submenu-others">
          <span class="submenu-others-label">その他のメニュー</span>
          <ul class="submenu-others-list">
            <li class="submenu-others-item">チャーシュー丼</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .menu-title-wrap {
    display: flex;
    align-items: center;
    gap: clamp(12px, 2vw, 20px);
  }

  .menu-deco {
    flex-shrink: 0;
    width: clamp(60px, 8vw, 90px);
    height: auto;
    opacity: 0.9;
    pointer-events: none;
  }

  .menu-title {
    font-size: clamp(1.5rem, 8vw, 2.5rem);
    font-weight: bold;
  }

  .title-small {
    font-size: clamp(0.8rem, 8vw, 1.2rem);
  }

  .menu-list {
    display: flex;
    flex-direction: column;
    gap: 60px;
    margin-top: 200px;
  }

  .menu-item {
    display: flex;
    gap: clamp(24px, 5vw, 90px);
  }

  .menu-item + .menu-item {
    margin-top: clamp(80px, 20vw, 300px);
  }

  .menu-text {
    position: relative;
  }

  .menu-text,
  .menu-image {
    flex: 1 1 0;
    min-width: 0;
  }

  .menu-item:nth-child(even) {
    flex-direction: row-reverse;
  }

  .text {
    margin-top: 40px;
  }

  .menu-image {
    flex: 1;
    max-width: 700px;
  }

  .submenu {
    margin-top: clamp(80px, 20vw, 300px);
  }
  .submenu-head {
    text-align: center;
    margin-bottom: 56px;
  }
  .submenu-label {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 12px;
  }
  .submenu-heading {
    font-size: clamp(1.25rem, 5vw, 1.75rem);
    font-weight: bold;
  }
  /* 画像ありメニュー：2点を中央寄せで見せる */
  .submenu-list {
    justify-content: center;
    gap: clamp(24px, 5vw, 64px);
  }
  .submenu-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .submenu-image {
    max-width: 200px;
  }
  .submenu-name {
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    font-weight: bold;
    text-align: center;
  }
  /* 画像なしメニュー：「こんな一品も」程度に軽く添える */
  .submenu-others {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-top: clamp(48px, 8vw, 80px);
    padding-top: clamp(32px, 5vw, 48px);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }
  .submenu-others-label {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.6);
  }
  .submenu-others-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 16px;
  }
  .submenu-others-item {
    padding: 8px 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 999px;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
  }

  @include tb {
    .menu-item,
    .menu-item:nth-child(even) {
      flex-direction: column;
    }

    .menu-text {
      margin: 0 auto;
    }

    .menu-image { 
      max-width: 400px; 
      margin: 0 auto;
      }
    }

    .image {
      text-align: center;
    }

  @include sp {
    
  }
</style>